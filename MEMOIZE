/**
 * @param {Function} fn
 * @return {Function}
 */
function memoize(fn) {
    
    const cache = new Map();
    let callCount = 0;

    return function(...args) {
        
        
        const key = args.join(',');

        
        if (cache.has(key)) {
            return cache.get(key);
        }

        
        callCount++;
        const result = fn(...args);
        
        
        cache.set(key, result);
        
        return result;
    }
}
